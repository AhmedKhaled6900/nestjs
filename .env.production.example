# Production environment — copy to .env.production and fill values
# Usage: docker compose --env-file .env.production -f docker-compose.prod.yml up -d --build

POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_DB=aqar

PORT=3000
APP_URL=https://api.yourdomain.com
CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com
SWAGGER_ENABLED=false

JWT_ACCESS_SECRET=CHANGE_ME_GENERATE_64_CHAR_RANDOM_STRING_FOR_ACCESS
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_64_CHAR_RANDOM_STRING_FOR_REFRESH
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api.yourdomain.com/auth/google/callback

OTP_EXPIRY_MINUTES=5
OTP_RATE_LIMIT_TTL=60
OTP_RATE_LIMIT_MAX=3

# Resend — https://resend.com/api-keys
# Verify your domain in Resend for production sender address
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM="Aqar <noreply@yourdomain.com>"

# First deploy only
RUN_SEED=true
SEED_ADMIN=true
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD_MIN_12
