NODE_ENV=development
PORT=3000

DATABASE_URL="postgresql://postgres:password@localhost:5432/aqar?schema=public"

JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars-long"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars-long"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3000/auth/google/callback"

APP_URL="http://localhost:3000"
CORS_ORIGIN="http://localhost:3000,http://localhost:5173"
SWAGGER_ENABLED=true

# Dev only — set SEED_ADMIN=true on first deploy in production
SEED_ADMIN=true
ADMIN_EMAIL="admin@aqar.com"
ADMIN_PASSWORD="Admin@123456"

OTP_EXPIRY_MINUTES=5
OTP_RATE_LIMIT_TTL=60
OTP_RATE_LIMIT_MAX=3
