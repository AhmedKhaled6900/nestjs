NODE_ENV=development
PORT=3000

DATABASE_URL="postgresql://postgres:password@localhost:5432/aqar?schema=public"
# Neon: use pooler for app (add &pgbouncer=true), direct host for migrate/seed
# DIRECT_URL="postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/db?sslmode=require"
# Local dev: set DIRECT_URL same as DATABASE_URL
DIRECT_URL="postgresql://postgres:password@localhost:5432/aqar?schema=public"

JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars-long"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars-long"
# Dev-friendly TTLs — use 15m / 7d in production
JWT_ACCESS_EXPIRES_IN="7d"
JWT_REFRESH_EXPIRES_IN="30d"

GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3000/auth/google/callback"

APP_URL="http://localhost:3000"
CORS_ORIGIN="http://localhost:3000,http://localhost:5173"
SWAGGER_ENABLED=true

# Dev only — set SEED_ADMIN=true on first deploy in production
SEED_ADMIN=true
ADMIN_EMAIL="admin@aqar.com"
ADMIN_PASSWORD="Admin@123456"

OTP_EXPIRY_MINUTES=5
OTP_RATE_LIMIT_TTL=60
OTP_RATE_LIMIT_MAX=3

# Resend — https://resend.com/api-keys
# Dev: use onboarding@resend.dev (sends only to your Resend account email)
# Prod: verify your domain and use e.g. Aqar <noreply@yourdomain.com>
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM="Aqar <onboarding@resend.dev>"

# Firebase Cloud Messaging (free) — Project Settings → Service accounts → Generate new private key
# Paste private key with \n for line breaks, or use a single line in quotes
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"
