        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RegisterPendingResponseDto"
                }
              }
            }
          },
          "409": {
            "description": "Email already registered"
          }
        },
        "tags": [
          "Auth"
        ]
      }
    },
