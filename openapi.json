  "info": {
    "title": "Aqar API",
    "description": "Rental Property Platform — Authentication, Authorization (RBAC), Properties & Bookings",
    "version": "1.0",
    "contact": {}
  },
  "tags": [
    {
      "name": "Auth",
      "description": "Registration, login, OTP, OAuth, password reset & tokens"
    },
    {
      "name": "Categories",
      "description": "Property category tree"
    },
    {
      "name": "Properties",
      "description": "Property listings and images"
    },
    {
      "name": "Admin - Properties",
      "description": "Admin property review"
    },
    {
      "name": "Bookings",
      "description": "Booking management (RBAC protected)"
    },
    {
      "name": "Health",
      "description": "Health check"
    },
    {
      "name": "Owner Profile",
      "description": "Owner KYC profile completion"
    },
    {
      "name": "Admin - Owner Review",
      "description": "Admin approve/reject owner profiles"
    }
  ],
  "servers": [],
  "components": {
    "securitySchemes": {
      "access-token": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http",
        "in": "header"
      }
    },
    "schemas": {
      "RegisterDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Ahmed Ali"
          },
          "email": {
            "type": "string",
            "example": "ahmed@example.com"
          },
          "phone": {
            "type": "string",
            "example": "+201234567890"
          },
          "password": {
            "type": "string",
            "example": "password123",
            "minLength": 8
          },
          "role": {
            "type": "string",
            "enum": [
              "CUSTOMER",
              "OWNER"
            ],
            "example": "CUSTOMER",
            "description": "CUSTOMER or OWNER only"
          }
        },
        "required": [
          "name",
          "email",
          "phone",
          "password",
          "role"
        ]
      },
      "UserResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "uuid-here"
          },
          "name": {
            "type": "string",
            "example": "Ahmed Ali"
          },
          "email": {
            "type": "object",
            "example": "ahmed@example.com",
            "nullable": true
          },
          "phone": {
            "type": "object",
            "example": "+201234567890",
            "nullable": true
          },
          "role": {
            "type": "string",
            "enum": [
              "ADMIN",
              "OWNER",
              "CUSTOMER"
            ],
            "example": "CUSTOMER"
          },
          "isVerified": {
            "type": "boolean",
            "example": false,
            "description": "Whether email has been verified"
          },
          "isProfileComplete": {
            "type": "boolean",
            "description": "True if owner submitted extended profile (not INCOMPLETE)",
            "example": false
          },
          "profileStatus": {
            "type": "string",
            "enum": [
              "INCOMPLETE",
              "BASIC_DONE",
              "KYC_PENDING",
              "VERIFIED",
              "REJECTED"
            ],
            "example": "INCOMPLETE"
          },
          "ownerType": {
            "type": "object",
            "example": null,
            "description": "Set after profile completion"
          }
        },
        "required": [
          "id",
          "name",
          "email",
          "phone",
          "role",
          "isVerified"
        ]
      },
      "RegisterPendingResponseDto": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "example": "Registration successful. Please verify your email."
          },
          "user": {
            "$ref": "#/components/schemas/UserResponseDto"
          }
        },
        "required": [
          "message",
          "user"
        ]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "ahmed@example.com"
          },
          "password": {
            "type": "string",
            "example": "password123"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "AuthResponseDto": {
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string",
            "description": "JWT access token (15 min)"
          },
          "refreshToken": {
            "type": "string",
            "description": "JWT refresh token (7 days)"
          },
          "user": {
            "$ref": "#/components/schemas/UserResponseDto"
          },
          "permissions": {
            "example": [
              "property.read",
              "booking.create"
            ],
            "description": "Permission actions for the user role (store in localStorage)",
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "accessToken",
          "refreshToken",
          "user",
          "permissions"
        ]
      },
      "VerifyEmailDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "ahmed@example.com"
          },
          "code": {
            "type": "string",
            "example": "123456",
            "description": "6-digit code from verification email"
          }
        },
        "required": [
          "email",
          "code"
        ]
      },
      "ResendVerificationDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "ahmed@example.com"
          }
        },
        "required": [
          "email"
        ]
      },
      "MessageResponseDto": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "example": "OTP sent successfully"
          }
        },
        "required": [
          "message"
        ]
      },
      "SendPhoneOtpDto": {
        "type": "object",
        "properties": {
          "phone": {
            "type": "string",
            "example": "+201234567890"
          }
        },
        "required": [
          "phone"
        ]
      },
      "VerifyPhoneOtpDto": {
        "type": "object",
        "properties": {
          "phone": {
            "type": "string",
            "example": "+201234567890"
          },
          "code": {
            "type": "string",
            "example": "123456",
            "description": "6-digit OTP from SMS"
          },
          "name": {
            "type": "string",
            "example": "Ahmed Ali",
            "description": "Used when auto-registering a new user"
          }
        },
        "required": [
          "phone",
          "code",
          "name"
        ]
      },
      "ForgotPasswordDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "ahmed@example.com",
            "description": "Required if phone is not provided"
          },
          "phone": {
            "type": "string",
            "example": "+201234567890",
            "description": "Required if email is not provided"
          }
        }
      },
      "VerifyResetOtpDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "ahmed@example.com"
          },
          "phone": {
            "type": "string",
            "example": "+201234567890"
          },
          "code": {
            "type": "string",
            "example": "123456",
            "description": "6-digit OTP code"
          }
        },
        "required": [
          "code"
        ]
      },
      "ResetPasswordDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "ahmed@example.com"
          },
          "phone": {
            "type": "string",
            "example": "+201234567890"
          },
          "code": {
            "type": "string",
            "example": "123456"
          },
          "newPassword": {
            "type": "string",
            "example": "newPassword123",
            "minLength": 8
          }
        },
        "required": [
          "code",
          "newPassword"
        ]
      },
      "RefreshTokenDto": {
        "type": "object",
        "properties": {
          "refreshToken": {
            "type": "string",
            "description": "Refresh token from login/register response"
          }
        },
        "required": [
          "refreshToken"
        ]
      },
      "MeResponseDto": {
        "type": "object",
        "properties": {
          "user": {
            "$ref": "#/components/schemas/UserResponseDto"
          },
          "permissions": {
            "example": [
              "property.read",
              "booking.create"
            ],
            "description": "Permission actions for the user role",
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "user",
          "permissions"
        ]
      },
      "CreatePropertyDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "example": "Modern 3BR Apartment in Nasr City"
          },
          "description": {
            "type": "string",
            "example": "Spacious apartment with balcony and parking."
          },
          "price": {
            "type": "number",
            "example": 2500000
          },
          "city": {
            "type": "string",
            "example": "Cairo"
          },
          "area": {
            "type": "string",
            "example": "Nasr City"
          },
          "address": {
            "type": "string",
            "example": "123 Abbas El Akkad Street"
          },
          "latitude": {
            "type": "number",
            "example": 30.0626
          },
          "longitude": {
            "type": "number",
            "example": 31.3219
          },
          "bedrooms": {
            "type": "number",
            "example": 3
          },
          "bathrooms": {
            "type": "number",
            "example": 2
          },
          "areaSize": {
            "type": "number",
            "example": 180,
            "description": "Area in square meters"
          },
          "purpose": {
            "type": "string",
            "enum": [
              "SALE",
              "RENT"
            ],
            "example": "SALE"
          },
          "categoryId": {
            "type": "string",
            "example": "uuid-of-subcategory",
            "description": "Leaf subcategory ID"
          }
        },
        "required": [
          "title",
          "description",
          "price",
          "city",
          "area",
          "address",
          "purpose",
          "categoryId"
        ]
      },
      "UpdatePropertyDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "example": "Modern 3BR Apartment in Nasr City"
          },
          "description": {
            "type": "string",
            "example": "Spacious apartment with balcony and parking."
          },
          "price": {
            "type": "number",
            "example": 2500000
          },
          "city": {
            "type": "string",
            "example": "Cairo"
          },
          "area": {
            "type": "string",
            "example": "Nasr City"
          },
          "address": {
            "type": "string",
            "example": "123 Abbas El Akkad Street"
          },
          "latitude": {
            "type": "number",
            "example": 30.0626
          },
          "longitude": {
            "type": "number",
            "example": 31.3219
          },
          "bedrooms": {
            "type": "number",
            "example": 3
          },
          "bathrooms": {
            "type": "number",
            "example": 2
          },
          "areaSize": {
            "type": "number",
            "example": 180,
            "description": "Area in square meters"
          },
          "purpose": {
            "type": "string",
            "enum": [
              "SALE",
              "RENT"
            ],
            "example": "SALE"
          },
          "categoryId": {
            "type": "string",
            "example": "uuid-of-subcategory",
            "description": "Leaf subcategory ID"
          }
        }
      },
      "UploadPropertyImagesDto": {
        "type": "object",
        "properties": {
          "images": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "binary"
            },
            "description": "One or more property images (JPEG/PNG/WebP, max 10 MB each)"
          },
          "primaryIndex": {
            "type": "number",
            "example": 0,
            "description": "Index of uploaded file to mark as primary (0-based)"
          }
        },
        "required": [
          "images"
        ]
      },
      "UpdatePropertyImageDto": {
        "type": "object",
        "properties": {
          "isPrimary": {
            "type": "boolean",
            "example": true
          },
          "order": {
            "type": "number",
            "example": 1
          }
        }
      },
      "RejectPropertyDto": {
        "type": "object",
        "properties": {
          "reason": {
            "type": "string",
            "example": "Images are unclear or listing details are incomplete"
          }
        },
        "required": [
          "reason"
        ]
      },
      "CompleteOwnerProfileMultipartDto": {
        "type": "object",
        "properties": {
          "ownerType": {
            "type": "string",
            "enum": [
              "INDIVIDUAL",
              "COMPANY"
            ],
            "example": "INDIVIDUAL"
          },
          "companyName": {
            "type": "string",
            "example": "شركة العقارات المتميزة"
          },
          "whatsapp": {
            "type": "string",
            "example": "+201098765432"
          },
          "phone": {
            "type": "string",
            "example": "+201234567890"
          },
          "email": {
            "type": "string",
            "example": "owner@example.com"
          },
          "address": {
            "type": "string",
            "example": "123 Main Street"
          },
          "city": {
            "type": "string",
            "example": "Cairo"
          },
          "area": {
            "type": "string",
            "example": "Nasr City"
          },
          "bio": {
            "type": "string",
            "example": "Experienced property owner with 10+ years."
          },
          "nationalId": {
            "type": "string",
            "format": "binary",
            "description": "National ID card image — required for INDIVIDUAL"
          },
          "taxNumber": {
            "type": "string",
            "format": "binary",
            "description": "Tax card image — required for COMPANY"
          },
          "commercialRegister": {
            "type": "string",
            "format": "binary",
            "description": "Commercial register image — required for COMPANY"
          }
        },
        "required": [
          "ownerType"
        ]
      },
      "RejectOwnerProfileDto": {
        "type": "object",
        "properties": {
          "reason": {
            "type": "string",
            "example": "Invalid commercial register document"
          }
        },
        "required": [
          "reason"
        ]
      }
    }
  }
}