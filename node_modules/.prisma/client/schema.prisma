generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum AuthProvider {
  LOCAL
  GOOGLE
  PHONE
}

enum OtpPurpose {
  PHONE_AUTH
  PASSWORD_RESET
  EMAIL_VERIFICATION
}

enum RoleName {
  ADMIN
  OWNER
  CUSTOMER
  SERVICE_PROVIDER
}

enum OwnerType {
  INDIVIDUAL
  COMPANY
}

enum ProfileStatus {
  INCOMPLETE
  BASIC_DONE
  KYC_PENDING
  VERIFIED
  REJECTED
}

model User {
  id           String       @id @default(uuid())
  name         String
  email        String?      @unique
  phone        String?      @unique
  password     String?
  provider     AuthProvider @default(LOCAL)
  providerId   String?
  roleId       String
  isVerified   Boolean      @default(false)
  refreshToken String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  role                    Role                    @relation(fields: [roleId], references: [id])
  ownerProfile            OwnerProfile?
  properties              Property[]
  notifications           Notification[]
  deviceTokens            DeviceToken[]
  favorites               Favorite[]
  cartItems               CartItem[]
  propertyReviews         PropertyReview[]
  propertyComments        PropertyComment[]
  priceOffersAsCustomer   PriceOffer[]            @relation("CustomerPriceOffers")
  propertyRentals         PropertyRental[]        @relation("TenantRentals")
  attributesCreated       Attribute[]             @relation("AttributeCreator")
  serviceProviderProfile  ServiceProviderProfile?
  serviceOrdersAsCustomer ServiceOrder[]          @relation("CustomerServiceOrders")
  serviceLeadsAsCustomer  ServiceLead[]           @relation("CustomerServiceLeads")

  @@unique([provider, providerId])
  @@index([roleId])
  @@map("users")
}

model Role {
  id          String   @id @default(uuid())
  name        RoleName @unique
  description String?
  createdAt   DateTime @default(now())

  users           User[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid())
  action      String   @unique
  description String?
  createdAt   DateTime @default(now())

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model Otp {
  id        String     @id @default(uuid())
  target    String
  code      String
  purpose   OtpPurpose
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime   @default(now())

  @@index([target, purpose])
  @@map("otps")
}

model OwnerProfile {
  id                 String        @id @default(uuid())
  userId             String        @unique
  ownerType          OwnerType?
  companyName        String?
  taxNumber          String?
  commercialRegister String?
  nationalId         String?
  whatsapp           String?
  phone              String?
  email              String?
  address            String?
  city               String?
  area               String?
  bio                String?
  profileStatus      ProfileStatus @default(INCOMPLETE)
  rejectionReason    String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([profileStatus])
  @@map("owner_profiles")
}

enum PropertyPurpose {
  SALE
  RENT
}

enum PricePeriod {
  DAY
  MONTH
  YEAR
}

enum PropertyStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  SOLD
  RENTED
  SUSPENDED
}

model Category {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  parentId    String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent                Category?              @relation("CategoryTree", fields: [parentId], references: [id], onDelete: Restrict)
  children              Category[]             @relation("CategoryTree")
  properties            Property[]
  subcategoryAttributes SubcategoryAttribute[]

  @@index([parentId])
  @@index([isActive])
  @@map("categories")
}

model Property {
  id               String          @id @default(uuid())
  title            String
  description      String          @db.Text
  price            Decimal         @db.Decimal(14, 2)
  pricePeriod      PricePeriod?
  city             String
  area             String
  address          String
  latitude         Decimal?        @db.Decimal(10, 7)
  longitude        Decimal?        @db.Decimal(10, 7)
  bedrooms         Int?
  bathrooms        Int?
  areaSize         Decimal?        @db.Decimal(10, 2)
  purpose          PropertyPurpose
  status           PropertyStatus  @default(DRAFT)
  categoryId       String
  ownerId          String
  rejectionReason  String?
  suspensionReason String?
  suspendedAt      DateTime?
  videoUrl         String?
  isNegotiable     Boolean         @default(false)
  submittedAt      DateTime?
  approvedAt       DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  category        Category                 @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  owner           User                     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  images          PropertyImage[]
  favorites       Favorite[]
  cartItems       CartItem[]
  reviews         PropertyReview[]
  comments        PropertyComment[]
  priceOffers     PriceOffer[]
  rentals         PropertyRental[]
  attributeValues PropertyAttributeValue[]

  @@index([ownerId])
  @@index([categoryId])
  @@index([status])
  @@index([purpose])
  @@index([city])
  @@index([status, purpose])
  @@index([status, categoryId, purpose])
  @@index([ownerId, status])
  @@map("properties")
}

model PropertyImage {
  id         String   @id @default(uuid())
  propertyId String
  imageUrl   String
  isPrimary  Boolean  @default(false)
  order      Int      @default(0)
  createdAt  DateTime @default(now())

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([propertyId, order])
  @@index([propertyId, isPrimary])
  @@map("property_images")
}

enum NotificationType {
  USER_REGISTERED
  USER_EMAIL_VERIFIED
  OWNER_PROFILE_SUBMITTED
  OWNER_KYC_APPROVED
  OWNER_KYC_REJECTED
  PROPERTY_APPROVED
  PROPERTY_REJECTED
  PRICE_OFFER_RECEIVED
  PRICE_OFFER_ACCEPTED
  PRICE_OFFER_REJECTED
  PRICE_OFFER_COUNTERED
  PRICE_OFFER_EXPIRED
  PRICE_OFFER_NEGOTIATING_FAILED
  PROPERTY_RENTED
  SERVICE_PROVIDER_SUBMITTED
  SERVICE_PROVIDER_APPROVED
  SERVICE_PROVIDER_REJECTED
  SERVICE_PROVIDER_SUSPENDED
  SERVICE_ORDER_RECEIVED
  SERVICE_ORDER_ACCEPTED
  SERVICE_ORDER_REJECTED
  SERVICE_ORDER_STATUS_UPDATED
  SERVICE_LEAD_RECEIVED
  SERVICE_LEAD_STATUS_UPDATED
  PROVIDER_PROMOTION_ACTIVATED
}

enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
  NEGOTIATING
  NEGOTIATING_FAIL
}

enum OfferSenderRole {
  CUSTOMER
  OWNER
}

enum RentalSource {
  DIRECT_BOOKING
  NEGOTIATION
}

enum RentalStatus {
  ACTIVE
  CANCELLED
  COMPLETED
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  data      Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@map("notifications")
}

model DeviceToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  platform  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("device_tokens")
}

model Favorite {
  userId     String
  propertyId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@id([userId, propertyId])
  @@index([userId, createdAt])
  @@index([propertyId])
  @@map("favorites")
}

model CartItem {
  userId     String
  propertyId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@id([userId, propertyId])
  @@index([userId, createdAt])
  @@index([propertyId])
  @@map("cart_items")
}

model PropertyReview {
  id         String   @id @default(uuid())
  propertyId String
  userId     String
  rating     Int
  body       String   @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
  @@index([propertyId, createdAt])
  @@index([userId])
  @@map("property_reviews")
}

model PropertyComment {
  id         String   @id @default(uuid())
  propertyId String
  userId     String
  body       String   @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([propertyId, createdAt])
  @@index([userId])
  @@map("property_comments")
}

model PriceOffer {
  id                 String      @id @default(uuid())
  propertyId         String
  customerId         String
  status             OfferStatus @default(PENDING)
  expiresAt          DateTime
  customerOfferCount Int         @default(1)
  ownerOfferCount    Int         @default(0)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  property Property          @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  customer User              @relation("CustomerPriceOffers", fields: [customerId], references: [id], onDelete: Cascade)
  rounds   PriceOfferRound[]
  rental   PropertyRental?

  @@index([propertyId, status])
  @@index([customerId, status])
  @@index([status, expiresAt])
  @@map("price_offers")
}

model PriceOfferRound {
  id          String          @id @default(uuid())
  offerId     String
  senderRole  OfferSenderRole
  senderId    String
  price       Decimal         @db.Decimal(14, 2)
  pricePeriod PricePeriod
  duration    Int
  notes       String?         @db.Text
  createdAt   DateTime        @default(now())

  offer PriceOffer @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@index([offerId, createdAt])
  @@map("price_offer_rounds")
}

model PropertyRental {
  id          String       @id @default(uuid())
  propertyId  String
  tenantId    String
  offerId     String?      @unique
  source      RentalSource
  agreedPrice Decimal      @db.Decimal(14, 2)
  pricePeriod PricePeriod
  duration    Int
  startedAt   DateTime     @default(now())
  endsAt      DateTime
  status      RentalStatus @default(ACTIVE)
  notes       String?      @db.Text
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  property Property    @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant   User        @relation("TenantRentals", fields: [tenantId], references: [id], onDelete: Cascade)
  offer    PriceOffer? @relation(fields: [offerId], references: [id], onDelete: SetNull)

  @@index([propertyId, status])
  @@index([tenantId, status])
  @@index([endsAt])
  @@map("property_rentals")
}

enum AttributeType {
  TEXT
  NUMBER
  BOOLEAN
  SELECT
  MULTI_SELECT
  DATE
}

enum AttributeScope {
  SYSTEM
  COMPANY
}

model Attribute {
  id          String         @id @default(cuid())
  name        String
  slug        String         @unique
  type        AttributeType
  scope       AttributeScope
  options     Json?
  companyId   String?
  createdById String?
  isActive    Boolean        @default(true)
  sortOrder   Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  createdBy        User?                    @relation("AttributeCreator", fields: [createdById], references: [id], onDelete: SetNull)
  subcategoryLinks SubcategoryAttribute[]
  propertyValues   PropertyAttributeValue[]

  @@index([scope, isActive])
  @@index([companyId])
  @@map("attributes")
}

model SubcategoryAttribute {
  subcategoryId String
  attributeId   String
  isRequired    Boolean @default(false)
  sortOrder     Int     @default(0)

  subcategory Category  @relation(fields: [subcategoryId], references: [id], onDelete: Cascade)
  attribute   Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@id([subcategoryId, attributeId])
  @@index([subcategoryId, sortOrder])
  @@map("subcategory_attributes")
}

model PropertyAttributeValue {
  id          String  @id @default(cuid())
  propertyId  String
  attributeId String?

  customName String?
  customType AttributeType?

  value Json

  property  Property   @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  attribute Attribute? @relation(fields: [attributeId], references: [id], onDelete: SetNull)

  @@unique([propertyId, attributeId])
  @@index([propertyId])
  @@map("property_attribute_values")
}

enum ServiceProviderStatus {
  DRAFT
  PENDING
  APPROVED
  SUSPENDED
}

enum ServiceListingStatus {
  DRAFT
  ACTIVE
  PAUSED
}

enum ServiceOrderStatus {
  PENDING
  ACCEPTED
  PREPARING
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  REJECTED
}

enum ServiceLeadStatus {
  NEW
  CONTACTED
  QUOTED
  COMPLETED
  LOST
}

enum ProviderPromotionType {
  HERO
  FEATURED
}

enum ProviderPromotionStatus {
  PENDING_PAYMENT
  ACTIVE
  EXPIRED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

model ServiceCategory {
  id             String   @id @default(uuid())
  name           String
  slug           String   @unique
  description    String?
  commissionRate Decimal  @default(0) @db.Decimal(5, 4)
  isActive       Boolean  @default(true)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  providers ServiceProviderProfile[]
  listings  ServiceListing[]

  @@index([isActive, sortOrder])
  @@map("service_categories")
}

model ServiceProviderProfile {
  id                 String                @id @default(uuid())
  userId             String                @unique
  businessName       String
  categoryId         String
  description        String?               @db.Text
  logo               String?
  phone              String?
  whatsapp           String?
  nationalId         String?
  commercialRegister String?
  status             ServiceProviderStatus @default(DRAFT)
  menuDeliveryFee    Decimal               @default(0) @db.Decimal(14, 2)
  rejectionReason    String?
  suspensionReason   String?
  suspendedAt        DateTime?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  user          User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category      ServiceCategory           @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  coverageAreas ServiceCoverageArea[]
  menuItems     ServiceProviderMenuItem[]
  listings      ServiceListing[]
  orders        ServiceOrder[]
  leads         ServiceLead[]
  promotions    ProviderPromotion[]

  @@index([categoryId])
  @@index([status])
  @@map("service_provider_profiles")
}

model ServiceCoverageArea {
  id         String   @id @default(uuid())
  providerId String
  city       String
  area       String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  provider ServiceProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([providerId, city, area])
  @@index([city, area, isActive])
  @@index([providerId])
  @@map("service_coverage_areas")
}

model ServiceProviderMenuItem {
  id              String   @id @default(uuid())
  providerId      String
  name            String
  price           Decimal  @db.Decimal(14, 2)
  prepTimeMinutes Int
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  provider   ServiceProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)
  orderItems ServiceOrderItem[]

  @@index([providerId, isActive, sortOrder])
  @@map("service_provider_menu_items")
}

model ServiceListing {
  id          String               @id @default(uuid())
  providerId  String
  categoryId  String
  title       String
  description String?              @db.Text
  deliveryFee Decimal              @default(0) @db.Decimal(14, 2)
  menuItems   Json?
  metadata    Json?
  status      ServiceListingStatus @default(DRAFT)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  provider   ServiceProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)
  category   ServiceCategory        @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  orders     ServiceOrder[]
  promotions ProviderPromotion[]

  @@index([providerId, status])
  @@index([categoryId, status])
  @@map("service_listings")
}

model ServiceOrder {
  id              String             @id @default(uuid())
  customerId      String
  providerId      String
  listingId       String?
  status          ServiceOrderStatus @default(PENDING)
  subtotal        Decimal            @db.Decimal(14, 2)
  deliveryFee     Decimal            @default(0) @db.Decimal(14, 2)
  platformFee     Decimal            @default(0) @db.Decimal(14, 2)
  providerNet     Decimal            @db.Decimal(14, 2)
  deliveryCity    String
  deliveryArea    String?
  deliveryAddress String             @db.Text
  notes           String?            @db.Text
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  customer User                   @relation("CustomerServiceOrders", fields: [customerId], references: [id], onDelete: Cascade)
  provider ServiceProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)
  listing  ServiceListing?        @relation(fields: [listingId], references: [id], onDelete: SetNull)
  items    ServiceOrderItem[]

  @@index([customerId, status])
  @@index([providerId, status])
  @@index([status, createdAt])
  @@map("service_orders")
}

model ServiceOrderItem {
  id              String  @id @default(uuid())
  orderId         String
  menuItemId      String?
  name            String
  quantity        Int     @default(1)
  unitPrice       Decimal @db.Decimal(14, 2)
  prepTimeMinutes Int?
  notes           String?

  order    ServiceOrder             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem ServiceProviderMenuItem? @relation(fields: [menuItemId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([menuItemId])
  @@map("service_order_items")
}

model ServiceLead {
  id                String            @id @default(uuid())
  customerId        String
  providerId        String
  type              String
  pickupCity        String
  pickupArea        String?
  destination       String
  passengers        Int               @default(1)
  preferredDateTime DateTime?
  notes             String?           @db.Text
  status            ServiceLeadStatus @default(NEW)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  customer User                   @relation("CustomerServiceLeads", fields: [customerId], references: [id], onDelete: Cascade)
  provider ServiceProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([customerId, status])
  @@index([providerId, status])
  @@map("service_leads")
}

model ProviderPromotion {
  id            String                  @id @default(uuid())
  providerId    String
  listingId     String?
  type          ProviderPromotionType
  price         Decimal                 @db.Decimal(14, 2)
  paymentStatus PaymentStatus           @default(PENDING)
  paymobOrderId String?
  status        ProviderPromotionStatus @default(PENDING_PAYMENT)
  startsAt      DateTime?
  endsAt        DateTime?
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  provider ServiceProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)
  listing  ServiceListing?        @relation(fields: [listingId], references: [id], onDelete: SetNull)

  @@index([providerId, status])
  @@index([status, startsAt, endsAt])
  @@map("provider_promotions")
}
